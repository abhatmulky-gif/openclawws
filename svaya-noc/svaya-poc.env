# Svaya Cognitive RCA Engine POC - Environment Variables

# 1. UPSTASH REDIS (Event Bus)
# Get from: https://upstash.com/ (Create Free Redis Database)
REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_UPSTASH_ENDPOINT:PORT"

# 2. NEO4J AURA DB (Topology Graph)
# Get from: https://neo4j.com/cloud/platform/aura-graph-database/ (Create Free AuraDB Instance)
NEO4J_URI="neo4j+s://YOUR_INSTANCE_ID.databases.neo4j.io"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="YOUR_NEO4J_PASSWORD"

# 3. VECTOR DB (ChromaDB - Local)
# For the POC, we can run ChromaDB natively in Python without external API keys to save time,
# but if you prefer Pinecone, uncomment and add the keys below:
# PINECONE_API_KEY="YOUR_PINECONE_API_KEY"
# PINECONE_ENV="YOUR_PINECONE_ENVIRONMENT"

# 4. RUNPOD LLM ENDPOINT (Reasoning Engine)
# Your active RunPod URL for the Svaya AI Engine
RUNPOD_URL="https://YOUR_RUNPOD_ENDPOINT/generate"
